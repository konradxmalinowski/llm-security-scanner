# These variables are only needed for the optional demo vulnerable app
# (demo/chatbot_openai_app.py, installed via `uv pip install -e ".[demo]"`).
# They are NOT required to run the scanner CLI itself — llm-security-scanner
# is fully offline and never calls OpenAI/Anthropic/etc.

# Your OpenAI API key, used by the demo chatbot to generate real responses
# for the scanner to test against.
OPENAI_API_KEY=sk-...

# OpenAI model used by the demo chatbot.
OPENAI_LLM_MODEL=gpt-4o-mini
