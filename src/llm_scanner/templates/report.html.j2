<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LLM Security Scan - {{ report.target }}</title>
  <style>
    body { font-family: sans-serif; margin: 2em; color: #333; }
    h1 { color: #c0392b; }
    .meta { margin-bottom: 1em; }
    table { border-collapse: collapse; width: 100%; font-size: 0.9em; }
    th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; vertical-align: top; }
    th { background: #f0f0f0; font-weight: bold; }
    tr.critical { background: #ffdddd; }
    tr.high { background: #ffe8cc; }
    tr.medium { background: #fffacc; }
    .vulnerable { color: #c0392b; font-weight: bold; }
    .safe { color: #27ae60; }
    .accepted { color: #7f8c8d; font-style: italic; }
    .error { color: #8e44ad; font-weight: bold; }
    .suppressed { opacity: 0.7; }
    tr.errored { background: #f3e6fa; }
    .warning-banner {
      border-left: 4px solid #8e44ad;
      background: #f3e6fa;
      padding: 0.75em 1em;
      margin: 1em 0;
      color: #4a235a;
    }
    .payload { font-family: monospace; font-size: 0.85em; word-break: break-all; }
    tr.conflict { background: #fff3cd; }
    .conflict-flag { color: #b8860b; font-weight: bold; }
    .conf-badge {
      display: inline-block; padding: 1px 8px; border-radius: 10px;
      font-size: 0.8em; font-weight: bold; color: #fff;
    }
    .conf-high { background: #27ae60; }
    .conf-med { background: #e67e22; }
    .conf-low { background: #c0392b; }
    .conflict-callout {
      border-left: 4px solid #b8860b;
      background: #fff3cd;
      padding: 0.6em 1em;
      margin: 0.6em 0;
      color: #6b5300;
    }
    .finding-detail { margin: 1.2em 0; padding-top: 0.6em; border-top: 1px solid #eee; }
    .finding-detail h3 { margin-bottom: 0.3em; }
    .reasoning { white-space: pre-wrap; }
    .fingerprint { font-family: monospace; font-size: 0.85em; word-break: break-all; }
  </style>
</head>
<body>
  <h1>LLM Security Scan</h1>
  <div class="meta">
    <p><strong>Target:</strong> {{ report.target }}</p>
    <p><strong>Timestamp:</strong> {{ report.timestamp.isoformat() }}</p>
    <p><strong>Risk Score:</strong> {{ "%.1f"|format(report.risk_score) }}/10.0</p>
    <p><strong>Attacks:</strong> {{ report.successful_attacks }}/{{ report.total_attacks }} succeeded</p>
    {% if report.errored_attacks %}
    <p><strong>Not evaluated:</strong> {{ report.errored_attacks }}/{{ report.total_attacks }}</p>
    {% endif %}
  </div>
  {% if report.errored_attacks %}
  <div class="warning-banner">
    <strong>Incomplete scan.</strong> The judge failed to evaluate
    {{ report.errored_attacks }} of {{ report.total_attacks }} attack(s). Those findings are
    UNKNOWN, not safe, and are excluded from the risk score above — treat the score as a
    lower bound until the judge errors are resolved.
  </div>
  {% endif %}
  <h2>Findings</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th><th>Category</th><th>Name</th><th>Severity</th>
        <th>Result</th><th>Conf.</th><th>Source</th><th>Judge Error</th>
        <th>Payload</th><th>Recommendation</th>
      </tr>
    </thead>
    <tbody>
      {% for finding in report.findings %}
      <tr class="{% if finding.outcome == "error" %}errored{% elif finding.verdict_source == "conflict" %}conflict{% else %}{{ finding.severity }}{% endif %}{% if finding.suppressed %} suppressed{% endif %}">
        <td>{{ finding.attack_id }}</td>
        <td>{{ finding.owasp_category }}</td>
        <td>{{ finding.name }}</td>
        <td>{{ finding.severity }}</td>
        <td>
          {# ERROR is checked first: a finding the judge never evaluated must never render as "Safe". #}
          {% if finding.outcome == "error" %}<span class="error">ERROR</span>{% elif finding.suppressed %}<span class="accepted">Accepted</span>{% elif finding.verdict_source == "conflict" %}<span class="conflict-flag">VULNERABLE (CONFLICT)</span>{% elif finding.success %}<span class="vulnerable">VULNERABLE</span>{% else %}<span class="safe">Safe</span>{% endif %}
        </td>
        <td>
          {% set c = finding.confidence %}
          <span class="conf-badge {% if c >= 0.8 %}conf-high{% elif c >= 0.5 %}conf-med{% else %}conf-low{% endif %}">{{ "%.2f"|format(c) }}</span>
        </td>
        <td>{{ finding.verdict_source }}</td>
        <td>{{ finding.judge_error or "" }}</td>
        <td class="payload">{{ finding.payload }}</td>
        <td>{{ finding.recommendation }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>Finding Details</h2>
  {% for finding in report.findings %}
  <div class="finding-detail">
    <h3>{{ finding.attack_id }} &mdash; {{ finding.name }}</h3>
    <p>
      <strong>Outcome:</strong> {{ finding.outcome }} &nbsp;
      <strong>Confidence:</strong>
      {% set c = finding.confidence %}
      <span class="conf-badge {% if c >= 0.8 %}conf-high{% elif c >= 0.5 %}conf-med{% else %}conf-low{% endif %}">{{ "%.2f"|format(c) }}</span>
      &nbsp; <strong>Source:</strong> {{ finding.verdict_source or "n/a" }}
    </p>
    {% if finding.verdict_source == "conflict" %}
    <div class="conflict-callout">
      <strong>Conflict.</strong> A deterministic detector fired but the judge disagreed.
      This disagreement is surfaced, not silently resolved &mdash; review it manually.
    </div>
    {% endif %}
    <p><strong>Judge reasoning:</strong> <span class="reasoning">{{ finding.judge_reasoning or "(none)" }}</span></p>
    {% if finding.judge_error %}<p><strong>Judge error:</strong> {{ finding.judge_error }}</p>{% endif %}
    {% if finding.artifacts %}
    <table>
      <thead>
        <tr><th>Type</th><th>Detector</th><th>Fingerprint</th><th>Span</th><th>Conf.</th></tr>
      </thead>
      <tbody>
        {% for artifact in finding.artifacts %}
        {# Render the REDACTED fingerprint only. artifact.raw is never surfaced here -- #}
        {# a live secret in a CI-published HTML report would be the leak vector itself. #}
        <tr>
          <td>{{ artifact.type }}</td>
          <td>{{ artifact.detector }}</td>
          <td class="fingerprint">{{ artifact.fingerprint }}</td>
          <td>{{ artifact.span[0] }}:{{ artifact.span[1] }}</td>
          <td>{{ "%.2f"|format(artifact.confidence) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </div>
  {% endfor %}

  {% set seen_categories = [] %}
  {% set mapping_rows = [] %}
  {% for finding in report.findings %}
    {% if finding.owasp_category not in seen_categories and (finding.cwe_ids or finding.cvss_vector) %}
      {% set _ = seen_categories.append(finding.owasp_category) %}
      {% set _ = mapping_rows.append(finding) %}
    {% endif %}
  {% endfor %}
  {% if mapping_rows %}
  <h2>CWE / CVSS Mapping</h2>
  <table>
    <thead>
      <tr>
        <th>Category</th><th>CWE</th><th>CVSS Vector</th><th>CVSS Score</th>
      </tr>
    </thead>
    <tbody>
      {% for finding in mapping_rows %}
      <tr class="{{ finding.severity }}">
        <td>{{ finding.owasp_category }}</td>
        <td>{{ finding.cwe_ids | join(", ") }}</td>
        <td class="payload">{{ finding.cvss_vector }}</td>
        <td>{{ "%.1f"|format(finding.cvss_score) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</body>
</html>
